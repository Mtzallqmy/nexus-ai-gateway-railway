// Moataz AI Gateway — Railway-ready Prisma schema
// Database: PostgreSQL on Railway

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Provider {
  id                String   @id @default(cuid())
  name              String
  slug              String   @unique
  description       String?  @db.Text
  baseUrl           String   @default("")
  region            String?
  litellmId         String   @unique
  apiKeyEncrypted   String?  @db.Text
  apiKeyMasked      String?
  defaultModel      String?
  status            String   @default("active")
  supportedFeatures Json     @default("[]")
  latencyMs         Int      @default(0)
  uptimePct         Float    @default(100)
  requestCount      Int      @default(0)
  errorRate         Float    @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  models       Model[]
  healthChecks HealthCheck[]
  logs         LogEntry[]
  validations  ValidationResult[]

  @@index([slug])
  @@index([status])
}

model Model {
  id              String   @id @default(cuid())
  providerId      String
  provider        Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  providerName    String
  name            String
  slug            String
  description     String?  @db.Text
  contextWindow   Int      @default(8192)
  maxOutput       Int      @default(4096)
  inputPricePer1k Float    @default(0)
  outputPricePer1k Float   @default(0)
  capabilities    Json     @default("[]")
  modalities      Json     @default("[]")
  status          String   @default("active")
  benchmarkScore  Float?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([providerId, slug])
  @@index([providerId])
  @@index([status])
}

model ApiKey {
  id            String   @id @default(cuid())
  name          String
  keyPrefix     String
  keyHash       String   @unique
  maskedKey     String
  status        String   @default("active")
  lastUsedAt    DateTime?
  expiresAt     DateTime?
  scopes        Json     @default("[]")
  usageLimit    Int?
  usageCount    Int      @default(0)
  createdBy     String   @default("Admin")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status])
}

model UsageDaily {
  id           String   @id @default(cuid())
  date         DateTime
  providerId   String?
  providerName String
  modelId      String?
  modelName    String
  requestCount Int      @default(0)
  tokenCount   Int      @default(0)
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  cost         Float    @default(0)
  avgLatencyMs Int      @default(0)
  errorCount   Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([date, providerName, modelName])
  @@index([date])
}

model LogEntry {
  id           String   @id @default(cuid())
  timestamp    DateTime @default(now())
  level        String   @default("info")
  providerId   String?
  provider     Provider? @relation(fields: [providerId], references: [id], onDelete: SetNull)
  providerName String?
  modelId      String?
  modelName    String?
  method       String   @default("POST")
  path         String   @default("/v1/chat/completions")
  statusCode   Int      @default(200)
  durationMs   Int      @default(0)
  tokenCount   Int?
  cost         Float?
  userId       String?
  apiKeyId     String?
  message      String   @db.Text
  metadata     Json     @default("{}")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([timestamp])
  @@index([level])
}

model HealthCheck {
  id            String   @id @default(cuid())
  providerId    String
  provider      Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  providerName  String
  status        String   @default("healthy")
  latencyMs     Int      @default(0)
  lastCheckedAt DateTime @default(now())
  uptimePct     Float    @default(100)
  incidents     Int      @default(0)
  region        String?
  details       Json     @default("{}")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([providerId])
  @@index([lastCheckedAt])
}

model ValidationResult {
  id           String   @id @default(cuid())
  providerId   String?
  provider     Provider? @relation(fields: [providerId], references: [id], onDelete: SetNull)
  providerName String
  modelId      String?
  modelName    String?
  testName     String   @default("API key validation")
  status       String   @default("skipped")
  durationMs   Int      @default(0)
  score        Float?
  message      String   @db.Text
  checkedAt    DateTime @default(now())
  category     String   @default("connectivity")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([providerName])
  @@index([checkedAt])
}

model TeamMember {
  id           String   @id @default(cuid())
  userId       String   @unique
  name         String
  email        String   @unique
  avatarUrl    String?
  role         String   @default("Admin")
  roleId       String   @default("role_admin")
  status       String   @default("active")
  lastActiveAt DateTime?
  permissions  Json     @default("[]")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?  @db.Text
  isSystem    Boolean  @default(false)
  permissions Json     @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Permission {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?  @db.Text
  category    String   @default("general")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AuditLog {
  id          String   @id @default(cuid())
  actorId     String?
  actorName   String   @default("System")
  action      String
  target      String?
  status      String   @default("success")
  ipAddress   String?
  userAgent   String?
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([createdAt])
  @@index([action])
}

model AppNotification {
  id        String   @id @default(cuid())
  title     String
  message   String   @db.Text
  type      String   @default("info")
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Invoice {
  id        String   @id @default(cuid())
  number    String   @unique
  amount    Float    @default(0)
  status    String   @default("paid")
  issuedAt  DateTime @default(now())
  dueAt     DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PaymentMethod {
  id        String   @id @default(cuid())
  brand     String
  last4     String
  expMonth  Int
  expYear   Int
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
